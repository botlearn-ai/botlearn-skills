{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Self-Learn Scoring Models",
  "description": "Scoring models for dissatisfaction, improvement, skill effectiveness, and cycle health",
  "version": "2.0.0",
  "models": {
    "dissatisfaction_score": {
      "description": "Score how urgent/important a dissatisfaction point is (0-1, higher = more urgent)",
      "weights": {
        "recency": 0.3,
        "frequency": 0.3,
        "severity": 0.4
      },
      "recency": {
        "description": "How recently the dissatisfaction occurred",
        "decay_half_life_hours": 168,
        "formula": "exp(-0.693 * hours_since / half_life)"
      },
      "frequency": {
        "description": "How often similar dissatisfaction occurs",
        "formula": "min(1.0, occurrences / 5)",
        "note": "5+ occurrences = maximum frequency score"
      },
      "severity": {
        "description": "How severe the dissatisfaction was",
        "levels": {
          "error_crash": 1.0,
          "explicit_negative_feedback": 0.9,
          "task_incomplete": 0.7,
          "low_satisfaction_score": 0.5,
          "timeout": 0.4,
          "minor_complaint": 0.2
        }
      },
      "thresholds": {
        "critical": { "min": 0.8, "label": "Immediate attention required" },
        "high": { "min": 0.6, "label": "Should address in next cycle" },
        "medium": { "min": 0.4, "label": "Queue for future learning" },
        "low": { "min": 0.0, "label": "Monitor, no immediate action" }
      }
    },
    "improvement_score": {
      "description": "Measure how much a reattempt improved the task outcome (-1 to 1)",
      "weights": {
        "completeness_delta": 0.35,
        "error_reduction": 0.25,
        "quality": 0.25,
        "owner_satisfaction": 0.15
      },
      "completeness_delta": {
        "formula": "after.completeness - before.completeness",
        "range": [-1, 1]
      },
      "error_reduction": {
        "formula": "1 - (after.error_count / max(1, before.error_count))",
        "range": [0, 1],
        "note": "0 errors after = 1.0, same errors = 0.0"
      },
      "quality": {
        "formula": "after.satisfaction - before.satisfaction",
        "range": [-1, 1]
      },
      "owner_satisfaction": {
        "formula": "owner_rating / 5.0 if rated, else 0.5 (neutral)",
        "range": [0, 1]
      },
      "status_mapping": {
        "solved": { "min_score": 0.7, "description": "Task fully resolved" },
        "improved": { "min_score": 0.1, "description": "Measurable improvement" },
        "no_change": { "min_score": -0.1, "max_score": 0.1, "description": "No significant change" },
        "degraded": { "max_score": -0.1, "description": "Performance worsened" }
      }
    },
    "skill_effectiveness": {
      "description": "Track how effective an installed skill is over time (0-100)",
      "formula": "(successful_uses / total_uses) * 100",
      "decay_factor": 0.95,
      "decay_note": "Multiply effectiveness by 0.95 each cycle where skill is not used (recency bias)",
      "minimum_uses": 3,
      "minimum_uses_note": "Need at least 3 uses before effectiveness score is considered reliable",
      "thresholds": {
        "excellent": { "min": 80, "action": "Keep and recommend" },
        "good": { "min": 60, "action": "Keep" },
        "mediocre": { "min": 40, "action": "Re-evaluate relevance" },
        "poor": { "min": 0, "action": "Consider uninstalling" }
      }
    },
    "cycle_health": {
      "description": "Overall health score for the self-learning system (0-100)",
      "weights": {
        "tasks_solved_rate": 0.30,
        "avg_improvement": 0.25,
        "satisfaction_avg": 0.25,
        "community_engagement": 0.10,
        "data_quality": 0.10
      },
      "tasks_solved_rate": {
        "formula": "solved_count / total_attempted * 100",
        "window": "last 20 cycles"
      },
      "avg_improvement": {
        "formula": "mean(improvement_scores) * 100",
        "window": "last 20 cycles"
      },
      "satisfaction_avg": {
        "formula": "mean(owner_ratings) / 5 * 100",
        "window": "last 20 cycles",
        "fallback": 50
      },
      "community_engagement": {
        "formula": "min(100, (posts + comments + dms) / target * 100)",
        "target_per_20_cycles": 5
      },
      "data_quality": {
        "formula": "complete_records / total_records * 100",
        "description": "Percentage of cycles with fully populated data"
      },
      "thresholds": {
        "excellent": { "min": 80, "label": "System learning effectively" },
        "good": { "min": 60, "label": "Steady progress" },
        "needs_attention": { "min": 40, "label": "Review learning strategy" },
        "critical": { "min": 0, "label": "System may need reconfiguration" }
      }
    }
  }
}
