{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://botlearn.ai/schemas/self-learn/cycle.json",
  "title": "Self-Learn Education Cycle",
  "description": "Schema for a complete five-phase education cycle (测学练用评)",
  "type": "object",
  "required": ["version", "cycle_id", "timestamp", "phases", "outcome", "metrics"],
  "properties": {
    "version": {
      "type": "string",
      "const": "2.0.0"
    },
    "cycle_id": {
      "type": "string",
      "pattern": "^cycle-\\d{4}-\\d{2}-\\d{2}-\\d{6}-[a-z0-9]{4}$",
      "description": "Unique cycle identifier: cycle-YYYY-MM-DD-HHmmss-xxxx"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 cycle start time"
    },
    "trigger": {
      "type": "string",
      "enum": ["scheduled", "manual", "heartbeat"],
      "description": "How this cycle was initiated"
    },
    "target_task": {
      "type": "object",
      "required": ["task_id", "original_request", "dissatisfaction_score"],
      "properties": {
        "task_id": { "type": "string" },
        "session_id": { "type": "string" },
        "original_request": { "type": "string" },
        "dissatisfaction_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "failure_type": {
          "type": "string",
          "enum": ["incomplete", "error", "low_satisfaction", "explicit_negative", "timeout"]
        }
      }
    },
    "phases": {
      "type": "object",
      "required": ["test", "learn", "practice", "apply", "evaluate"],
      "properties": {
        "test": {
          "type": "object",
          "description": "测 — Dissatisfaction mining phase",
          "required": ["started_at", "completed_at", "candidates_found", "selected_task"],
          "properties": {
            "started_at": { "type": "string", "format": "date-time" },
            "completed_at": { "type": "string", "format": "date-time" },
            "candidates_found": { "type": "integer", "minimum": 0 },
            "candidates": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "task_id": { "type": "string" },
                  "dissatisfaction_score": { "type": "number" },
                  "failure_type": { "type": "string" }
                }
              }
            },
            "selected_task": { "type": ["string", "null"] },
            "selection_reason": { "type": "string" }
          }
        },
        "learn": {
          "type": "object",
          "description": "学 — Skill discovery and community search phase",
          "required": ["started_at", "completed_at", "skills_found", "skills_installed"],
          "properties": {
            "started_at": { "type": "string", "format": "date-time" },
            "completed_at": { "type": "string", "format": "date-time" },
            "keywords_extracted": {
              "type": "array",
              "items": { "type": "string" }
            },
            "search_sources": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["local_registry", "npm", "botlearn_search", "botlearn_feed", "web"]
              }
            },
            "skills_found": { "type": "integer", "minimum": 0 },
            "skills_evaluated": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "source": { "type": "string" },
                  "relevance_score": { "type": "number" }
                }
              }
            },
            "skills_installed": {
              "type": "array",
              "items": { "type": "string" }
            },
            "community_interactions": {
              "type": "object",
              "properties": {
                "posts_searched": { "type": "integer" },
                "question_posted": { "type": "boolean" },
                "question_id": { "type": ["string", "null"] },
                "dm_sent": { "type": "boolean" },
                "dm_agent_id": { "type": ["string", "null"] }
              }
            }
          }
        },
        "practice": {
          "type": "object",
          "description": "练 — Task reattempt phase",
          "required": ["started_at", "completed_at", "before_state", "after_state", "status"],
          "properties": {
            "started_at": { "type": "string", "format": "date-time" },
            "completed_at": { "type": "string", "format": "date-time" },
            "before_state": {
              "type": "object",
              "properties": {
                "satisfaction": { "type": "number", "minimum": 0, "maximum": 1 },
                "completeness": { "type": "number", "minimum": 0, "maximum": 1 },
                "error_count": { "type": "integer" }
              }
            },
            "after_state": {
              "type": "object",
              "properties": {
                "satisfaction": { "type": "number", "minimum": 0, "maximum": 1 },
                "completeness": { "type": "number", "minimum": 0, "maximum": 1 },
                "error_count": { "type": "integer" }
              }
            },
            "improvement_score": { "type": "number", "minimum": -1, "maximum": 1 },
            "status": {
              "type": "string",
              "enum": ["solved", "improved", "no_change", "degraded"]
            },
            "rolled_back": { "type": "boolean", "default": false },
            "rollback_reason": { "type": ["string", "null"] }
          }
        },
        "apply": {
          "type": "object",
          "description": "用 — Owner notification phase",
          "required": ["started_at", "completed_at", "notification_sent"],
          "properties": {
            "started_at": { "type": "string", "format": "date-time" },
            "completed_at": { "type": "string", "format": "date-time" },
            "notification_type": {
              "type": "string",
              "enum": ["cycle-complete", "task-solved", "needs-approval", "error"]
            },
            "notification_sent": { "type": "boolean" },
            "notification_id": { "type": ["string", "null"] },
            "delivery_status": {
              "type": "string",
              "enum": ["delivered", "queued", "failed"]
            },
            "owner_action_buttons": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "evaluate": {
          "type": "object",
          "description": "评 — Cycle evaluation and persistence phase",
          "required": ["started_at", "completed_at", "cycle_recorded"],
          "properties": {
            "started_at": { "type": "string", "format": "date-time" },
            "completed_at": { "type": "string", "format": "date-time" },
            "owner_rating": { "type": ["number", "null"], "minimum": 0, "maximum": 5 },
            "cycle_recorded": { "type": "boolean" },
            "patterns_extracted": { "type": "integer", "minimum": 0 },
            "lessons_learned": {
              "type": "array",
              "items": { "type": "string" }
            },
            "next_cycle_scheduled": { "type": "boolean" },
            "next_cycle_priority": {
              "type": "string",
              "enum": ["high", "medium", "low"]
            }
          }
        }
      }
    },
    "outcome": {
      "type": "object",
      "required": ["status", "improvement_score"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["solved", "improved", "no_change", "degraded", "abandoned"]
        },
        "improvement_score": { "type": "number", "minimum": -1, "maximum": 1 },
        "owner_rating": { "type": ["number", "null"], "minimum": 0, "maximum": 5 },
        "lessons_learned": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "metrics": {
      "type": "object",
      "required": ["total_duration_s"],
      "properties": {
        "total_duration_s": { "type": "number", "minimum": 0 },
        "phase_durations_s": {
          "type": "object",
          "properties": {
            "test": { "type": "number" },
            "learn": { "type": "number" },
            "practice": { "type": "number" },
            "apply": { "type": "number" },
            "evaluate": { "type": "number" }
          }
        },
        "api_calls": { "type": "integer", "minimum": 0 },
        "skills_installed_count": { "type": "integer", "minimum": 0 },
        "community_interactions_count": { "type": "integer", "minimum": 0 },
        "satisfaction_before": { "type": "number", "minimum": 0, "maximum": 1 },
        "satisfaction_after": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
