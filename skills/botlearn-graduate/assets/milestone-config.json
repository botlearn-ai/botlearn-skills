{
  "version": "2.0.0",
  "description": "Day 1-7 milestone definitions with detection methods and scoring",
  "totalPoints": 200,
  "grading": {
    "gold":        { "min": 160, "label": "Gold Graduate",      "emoji": "🥇" },
    "silver":      { "min": 120, "label": "Silver Graduate",    "emoji": "🥈" },
    "bronze":      { "min": 80,  "label": "Bronze Graduate",    "emoji": "🥉" },
    "participant": { "min": 0,   "label": "Journey Participant","emoji": "🎓" }
  },
  "milestones": [
    {
      "day": 1,
      "id": "day1-activation",
      "name": "First Activation",
      "phase": "activation",
      "items": [
        { "id": "d1-agent-running",   "name": "Agent Running & Responsive", "points": 10, "detect": "check_agent_process" },
        { "id": "d1-first-task",      "name": "First Task Completed",       "points": 10, "detect": "check_session_log_count >= 1" },
        { "id": "d1-first-skill",     "name": "First Skill Installed",      "points": 10, "detect": "check_skills_count >= 1" }
      ]
    },
    {
      "day": 2,
      "id": "day2-exploration",
      "name": "Ecosystem Exploration",
      "phase": "activation",
      "items": [
        { "id": "d2-three-tasks",      "name": "3+ Tasks Completed",          "points": 10, "detect": "check_session_log_count >= 3" },
        { "id": "d2-second-skill",     "name": "Second Skill Installed",      "points": 10, "detect": "check_skills_count >= 2" },
        { "id": "d2-config-modified",  "name": "Configuration Modified",      "points": 10, "detect": "check_config_modified" }
      ]
    },
    {
      "day": 3,
      "id": "day3-personalization",
      "name": "Identity Formation",
      "phase": "stability",
      "items": [
        { "id": "d3-soul-md",       "name": "SOUL.md Created",            "points": 15, "detect": "check_file_exists SOUL.md" },
        { "id": "d3-user-md",       "name": "USER.md Created",            "points": 10, "detect": "check_file_exists USER.md" },
        { "id": "d3-five-tasks",    "name": "5+ Tasks Completed",         "points": 5,  "detect": "check_session_log_count >= 5" }
      ]
    },
    {
      "day": 4,
      "id": "day4-stability",
      "name": "Security & Trust",
      "phase": "stability",
      "items": [
        { "id": "d4-agents-md",     "name": "AGENTS.md Created",          "points": 15, "detect": "check_file_exists AGENTS.md" },
        { "id": "d4-three-skills",  "name": "3+ Skills Installed",        "points": 10, "detect": "check_skills_count >= 3" },
        { "id": "d4-memory-docs",   "name": "Memory Documents Added",     "points": 5,  "detect": "check_memory_doc_count >= 1" }
      ]
    },
    {
      "day": 5,
      "id": "day5-reinforcement",
      "name": "Workflow Discovery",
      "phase": "reinforcement",
      "items": [
        { "id": "d5-workflow",        "name": "First Workflow Established", "points": 15, "detect": "check_repeated_task_pattern" },
        { "id": "d5-five-skills",     "name": "5+ Skills Installed",       "points": 10, "detect": "check_skills_count >= 5" },
        { "id": "d5-ten-tasks",       "name": "10+ Tasks Completed",       "points": 5,  "detect": "check_session_log_count >= 10" }
      ]
    },
    {
      "day": 6,
      "id": "day6-optimization",
      "name": "Self-Improvement",
      "phase": "reinforcement",
      "items": [
        { "id": "d6-self-improve",     "name": "Self-Improvement Enabled",   "points": 15, "detect": "check_learnings_dir_exists" },
        { "id": "d6-community",        "name": "Community Engagement",       "points": 10, "detect": "check_botlearn_activity" },
        { "id": "d6-advanced-task",    "name": "Advanced Task Completed",    "points": 5,  "detect": "check_complex_task_success" }
      ]
    },
    {
      "day": 7,
      "id": "day7-graduation",
      "name": "Graduation Day",
      "phase": "graduation",
      "postCeremony": true,
      "note": "Day 7 milestones are only evaluated AFTER the graduation pipeline completes (Stage 6). They cannot be detected during Stage 3 because the files they check are produced by Stage 4-6 itself.",
      "items": [
        { "id": "d7-retrospective",   "name": "Retrospective Completed",    "points": 10, "detect": "check_graduation_report",  "postCeremony": true },
        { "id": "d7-exam",            "name": "Graduation Exam Taken",      "points": 5,  "detect": "check_exam_completed",     "postCeremony": true },
        { "id": "d7-ceremony",        "name": "Ceremony Attended",          "points": 5,  "detect": "check_ceremony_completed", "postCeremony": true }
      ]
    }
  ]
}
