{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenClaw Doctor Channel Configuration",
  "description": "JSON Schema for ~/.openclaw/config/doctor-channels.json",
  "type": "object",
  "required": ["default_channel", "channels"],
  "properties": {
    "default_channel": {
      "type": "string",
      "enum": ["terminal", "browser", "slack", "dingtalk", "feishu", "discord", "email"],
      "description": "Default delivery channel"
    },
    "channels": {
      "type": "object",
      "properties": {
        "terminal": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true }
          },
          "required": ["enabled"]
        },
        "browser": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "auto_open_on_macos": { "type": "boolean", "default": true }
          },
          "required": ["enabled"]
        },
        "slack": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "webhook_url": { "type": "string", "format": "uri" }
          },
          "required": ["enabled"],
          "if": { "properties": { "enabled": { "const": true } } },
          "then": { "required": ["webhook_url"] }
        },
        "dingtalk": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "webhook_url": { "type": "string", "format": "uri" },
            "secret": { "type": "string", "description": "DingTalk signing secret (optional)" }
          },
          "required": ["enabled"],
          "if": { "properties": { "enabled": { "const": true } } },
          "then": { "required": ["webhook_url"] }
        },
        "feishu": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "webhook_url": { "type": "string", "format": "uri" }
          },
          "required": ["enabled"],
          "if": { "properties": { "enabled": { "const": true } } },
          "then": { "required": ["webhook_url"] }
        },
        "discord": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "webhook_url": { "type": "string", "format": "uri" }
          },
          "required": ["enabled"],
          "if": { "properties": { "enabled": { "const": true } } },
          "then": { "required": ["webhook_url"] }
        },
        "email": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "to": { "type": "string", "format": "email" },
            "smtp_host": { "type": "string", "default": "localhost" },
            "smtp_port": { "type": "integer", "default": 25 },
            "from": { "type": "string" },
            "subject_prefix": { "type": "string", "default": "[OpenClaw Doctor]" }
          },
          "required": ["enabled"],
          "if": { "properties": { "enabled": { "const": true } } },
          "then": { "required": ["to"] }
        }
      }
    }
  }
}
