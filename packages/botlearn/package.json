{
  "name": "botlearn",
  "version": "0.1.0",
  "description": "BotLearn OpenClaw Skills SDK — types, validator, and utilities for @botlearn/* skill packages",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./registry": {
      "types": "./dist/index.d.ts",
      "import": "./registry/skills-registry.json",
      "require": "./registry/skills-registry.json"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "registry",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "botlearn",
    "openclaw",
    "skills",
    "agent"
  ],
  "author": "BotLearn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/readai-team/botlearn-awesome-skills.git",
    "directory": "packages/botlearn"
  },
  "homepage": "https://github.com/readai-team/botlearn-awesome-skills/tree/main/packages/botlearn",
  "bugs": {
    "url": "https://github.com/readai-team/botlearn-awesome-skills/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
