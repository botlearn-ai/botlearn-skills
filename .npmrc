# === BotLearn 发布配置 ===

# 默认 registry
registry=https://registry.npmjs.org/

# @botlearn scope 的 registry（如需默认发布到 skills.ai，取消下行注释）
# @botlearn:registry=https://npm.skills.ai/

# === Auth Tokens（使用环境变量，不要硬编码） ===
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
//npm.skills.ai/:_authToken=${SKILLS_AI_TOKEN}

# === 发布行为 ===
# @botlearn scope 包默认 restricted，必须显式设为 public
access=public
